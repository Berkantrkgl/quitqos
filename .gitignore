# ─────────────────────────────────────────────────────────────
# QuitQOS — root .gitignore (monorepo)
# backend/ ve mobile/ kendi .gitignore'larına da sahiptir;
# burası tüm repo için ortak + güvenlik kurallarını kapsar.
# ─────────────────────────────────────────────────────────────

# ── Secrets / env ────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.local

# Firebase service account & credentials (ASLA commit edilmemeli)
**/google-services.json
**/GoogleService-Info.plist
**/firebase-service-account*.json
**/serviceAccountKey*.json
*.keystore
*.jks
*.p8
*.p12
*.mobileprovision

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editör / IDE ─────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
!.vscode/extensions.json
*.swp
*.swo
*~

# ── Loglar ───────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Claude / AI araçları ─────────────────────────────────────
# Kişisel & gizli olanlar ignore; paylaşılan settings.json ve
# CLAUDE.md takip edilir (ekibe faydalı).
**/.claude/settings.local.json
**/.claude/.credentials.json
**/.claude/projects/
**/.claude/todos/
CLAUDE.local.md
.aider*
.cursorignore

# ── Backend (Java / Maven) ───────────────────────────────────
backend/target/
!backend/**/src/main/**/target/
!backend/**/src/test/**/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/HELP.md
backend/build/
!backend/**/src/main/**/build/
!backend/**/src/test/**/build/

# STS
backend/.apt_generated
backend/.classpath
backend/.factorypath
backend/.project
backend/.settings
backend/.springBeans
backend/.sts4-cache

# NetBeans
backend/nbproject/private/
backend/nbbuild/
backend/nbdist/
backend/.nb-gradle/

# ── Mobile (Node / Expo / RN) ────────────────────────────────
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/ios/
mobile/android/
mobile/*.tsbuildinfo
mobile/.expo-shared/
mobile/expo-env.d.ts
mobile/.kotlin/
mobile/*.orig.*
mobile/.metro-health-check*
mobile/example
mobile/.env*.local

# Local-only project guide for Claude (not committed)
CLAUDE.md
.claude
quitqos-cv-summary.md