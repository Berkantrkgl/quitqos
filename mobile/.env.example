# Expo public env vars — inlined into the app bundle at build time.
# These are NOT secrets (they ship inside the published app binary), but are
# kept out of source so the public repo carries no project-specific identifiers.
# Copy to .env (gitignored) and fill in your own values.

# Backend API base URL (Spring Boot). Leave unset for local dev — the app then
# defaults to the emulator host (Android 10.0.2.2 / iOS localhost) on :8080.
EXPO_PUBLIC_API_URL=https://api.your-domain.com/api/v1

# Legal pages base URL (privacy.html / terms.html live here)
EXPO_PUBLIC_LEGAL_BASE_URL=https://legal.your-domain.com

# Expo / EAS
EXPO_PUBLIC_EXPO_OWNER=your-expo-owner
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
EXPO_PUBLIC_UPDATES_URL=https://u.expo.dev/your-eas-project-id

# App identifiers
EXPO_PUBLIC_IOS_BUNDLE_ID=com.example.quitqos
EXPO_PUBLIC_ANDROID_PACKAGE=com.example.quitqos

# Google Sign-In (public OAuth client IDs)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-google-ios-client-id
