# Production env for the quitqos-backend container on Hetzner.
# Lives at /home/deploy/quitqos/.env.quitqos on the server (chmod 600), never committed.
# Copy this file there and fill in real values.

DB_URL=jdbc:postgresql://your-aiven-host.aivencloud.com:PORT/quitqos?sslmode=require
DB_USERNAME=avnadmin
DB_PASSWORD=

# Base64-encoded HMAC secret, distinct from any other project's JWT secret.
JWT_SECRET=

# FIREBASE_CREDENTIALS is set directly in docker-compose.prod.yml (points at the
# mounted service-account file), not needed here.
